# Copy to .env for local development: cp .env.example .env
# All values below match the docker-compose.yml defaults.

# --- Kafka ---
DOCSTREAM_KAFKA__BOOTSTRAP_SERVERS=localhost:9092
DOCSTREAM_KAFKA__CLIENT_ID=docstream
# consumer group defaults are set per-service in code

# --- PostgreSQL ---
DOCSTREAM_POSTGRES__DSN=postgresql+asyncpg://docstream:docstream@localhost:5432/docstream

# --- Redis (idempotency / dedup) ---
DOCSTREAM_REDIS__URL=redis://localhost:6379/0

# --- Qdrant (vectors, used from Week 2) ---
DOCSTREAM_QDRANT__URL=http://localhost:6333
# DOCSTREAM_QDRANT__API_KEY=            # only for Qdrant Cloud
DOCSTREAM_QDRANT__COLLECTION=documents
DOCSTREAM_QDRANT__VECTOR_SIZE=1536

# --- Embeddings (enrichment worker, Week 2) ---
DOCSTREAM_EMBEDDING__PROVIDER=openai
DOCSTREAM_EMBEDDING__MODEL=text-embedding-3-small
DOCSTREAM_EMBEDDING__DIM=1536
DOCSTREAM_EMBEDDING__API_KEY=sk-...
# DOCSTREAM_EMBEDDING__BASE_URL=        # for Azure / OpenAI-compatible gateways
DOCSTREAM_EMBEDDING__CHUNK_SIZE=512
DOCSTREAM_EMBEDDING__CHUNK_OVERLAP=64

# --- LLM (enrichment worker, Week 2) ---
DOCSTREAM_LLM__PROVIDER=anthropic
DOCSTREAM_LLM__MODEL=claude-sonnet-4-6
DOCSTREAM_LLM__API_KEY=sk-ant-...
# DOCSTREAM_LLM__BASE_URL=
DOCSTREAM_LLM__MAX_TOKENS=1024

# --- Consumer retry / DLQ (workers, Week 2) ---
DOCSTREAM_CONSUMER__MAX_ATTEMPTS=5
DOCSTREAM_CONSUMER__BACKOFF_SECONDS=1.0

# --- Service ---
DOCSTREAM_ENV=local
DOCSTREAM_LOG_LEVEL=INFO
